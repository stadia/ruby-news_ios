### Swift / Xcode
# XcodeGen — .xcodeproj is generated from project.yml and not tracked,
# but the SwiftPM lock file (Package.resolved) IS tracked so dependency
# versions stay pinned across machines. Drill down: ignore each level's
# contents (not the dirs themselves) so the nested lock file can be re-included.
ruby-news.xcodeproj/*
!ruby-news.xcodeproj/project.xcworkspace/
ruby-news.xcodeproj/project.xcworkspace/*
!ruby-news.xcodeproj/project.xcworkspace/xcshareddata/
ruby-news.xcodeproj/project.xcworkspace/xcshareddata/*
!ruby-news.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/
ruby-news.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/*
!ruby-news.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved

# Xcode user settings
xcuserdata/

# Xcode build data
DerivedData/
.build/

# Swift/Obj-C specific
*.hmap

# App packaging
*.ipa
*.dSYM.zip
*.dSYM

# Playgrounds
timeline.xctimeline
playground.xcworkspace

# Swift Package Manager
# Packages/
# Package.pins
# Package.resolved
# *.xcodeproj
# .swiftpm

# CocoaPods
# Pods/
# *.xcworkspace

